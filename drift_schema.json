  "fixed_sql": [
    {
      "name": "categories",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"categories\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"name\" TEXT NOT NULL, \"slug\" TEXT NOT NULL UNIQUE);"
        }
      ]
    },
    {
      "name": "partners",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"partners\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"name\" TEXT NOT NULL, \"gender\" INTEGER NOT NULL, \"birthday\" TEXT NULL, \"created_at\" TEXT NOT NULL DEFAULT (CURRENT_TIMESTAMP), \"notes\" TEXT NULL, \"is_visible\" INTEGER NOT NULL DEFAULT 1 CHECK (\"is_visible\" IN (0, 1)));"
        }
      ]
    },
    {
      "name": "events",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"events\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"type\" INTEGER NOT NULL, \"date\" TEXT NOT NULL, \"time\" TEXT NOT NULL DEFAULT '2006-01-01T12:00:00.000 +10:00', \"notes\" TEXT NULL, \"created_at\" TEXT NOT NULL DEFAULT (CURRENT_TIMESTAMP));"
        }
      ]
    },
    {
      "name": "event_data_table",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"event_data_table\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"event_id\" INTEGER NOT NULL REFERENCES events (id) ON DELETE CASCADE, \"rating\" INTEGER NOT NULL CHECK(\"rating\" BETWEEN 0 AND 5), \"duration\" INTEGER NULL, \"user_orgasms\" INTEGER NULL CHECK(\"user_orgasms\" BETWEEN 0 AND 13));"
        }
      ]
    },
    {
      "name": "e_options",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"e_options\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"name\" TEXT NOT NULL, \"slug\" TEXT NOT NULL UNIQUE, \"category_id\" INTEGER NOT NULL REFERENCES categories (id), \"is_visible\" INTEGER NOT NULL DEFAULT 1 CHECK (\"is_visible\" IN (0, 1)), \"is_basic\" INTEGER NOT NULL DEFAULT 1 CHECK (\"is_basic\" IN (0, 1)));"
        }
      ]
    },
    {
      "name": "categories_types",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"categories_types\" (\"category_id\" INTEGER NOT NULL REFERENCES categories (id), \"type\" INTEGER NOT NULL, PRIMARY KEY (\"category_id\", \"type\"));"
        }
      ]
    },
    {
      "name": "events_options",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"events_options\" (\"event_id\" INTEGER NOT NULL REFERENCES events (id) ON DELETE CASCADE, \"option_id\" INTEGER NOT NULL REFERENCES e_options (id), \"test_status\" TEXT NULL, PRIMARY KEY (\"event_id\", \"option_id\"));"
        }
      ]
    },
    {
      "name": "events_partners",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"events_partners\" (\"event_id\" INTEGER NOT NULL REFERENCES events (id) ON DELETE CASCADE, \"partner_id\" INTEGER NOT NULL REFERENCES partners (id) ON DELETE CASCADE, \"partner_orgasms\" INTEGER NULL CHECK(\"partner_orgasms\" BETWEEN 0 AND 13), PRIMARY KEY (\"event_id\", \"partner_id\"));"
        }
      ]
    }
  ]
